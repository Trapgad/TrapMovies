const API_KEY = 'YOUR_V3_API_KEY_HERE'; // Use your v3 API Key string here
const BASE_URL = 'https://api.themoviedb.org/3';

async function fetchTrendingMovies() {
    // We add the api_key as a query parameter in the URL
    const url = `${BASE_URL}/trending/movie/day?api_key=${API_KEY}`;
    
    try {
        const response = await fetch(url);
        const data = await response.json();
        
        if (data.results) {
            displayMovies(data.results);
        }
    } catch (error) {
        console.error('Error fetching movies:', error);
    }
}

function displayMovies(movies) {
    const grid = document.querySelector('.movie-grid');
    if (!grid) return;
    
    grid.innerHTML = movies.map(movie => `
        <a href="movie.html?id=${movie.id}" class="movie-card-link">
            <div class="movie-card">
                <img src="https://image.tmdb.org/t/p/w500${movie.poster_path}" alt="${movie.title}">
                <h3>${movie.title}</h3>
            </div>
        </a>
    `).join('');
}

fetchTrendingMovies();

// Function to fetch specific movie details
async function fetchMovieDetails() {
    const detailsContainer = document.querySelector('.details-container');
    if (!detailsContainer) return;

    // Get ID from URL
    const params = new URLSearchParams(window.location.search);
    const movieId = params.get('id');

    if (!movieId) return;

    const response = await fetch(`${BASE_URL}/movie/${movieId}?api_key=${API_KEY}`);
    const movie = await response.json();

    // Render the details
    detailsContainer.innerHTML = `
        <div class="movie-poster">
            <img src="https://image.tmdb.org/t/p/w500${movie.poster_path}" alt="${movie.title}">
        </div>
        <div class="movie-info">
            <h1>${movie.title}</h1>
            <div class="meta">
                <span>${movie.release_date}</span> | 
                <span>⭐ ${movie.vote_average.toFixed(1)}/10</span>
            </div>
            <p class="synopsis">${movie.overview}</p>
            <button class="play-btn">▶ Watch Now</button>
        </div>
    `;
}

// Call this function
fetchMovieDetails();

